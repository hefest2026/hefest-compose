# SSO provider credentials — copy to .env.sso and fill in real values.
# Each group is all-or-nothing: leave an entire group blank to disable that provider.
# .env.sso is gitignored; never commit real credentials.

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create an app at https://console.cloud.google.com/apis/credentials
# Add an OAuth 2.0 Client ID (Web application type).
# Authorised redirect URI must match HEFEST_GOOGLE_REDIRECT_URI exactly (trailing slash matters).
HEFEST_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
HEFEST_GOOGLE_CLIENT_SECRET=your-google-client-secret
HEFEST_GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Microsoft / Entra ID (edu.mon.bg) ────────────────────────────────────────
# Register an app at https://portal.azure.com → Microsoft Entra ID → App registrations.
# Set the redirect URI to HEFEST_MICROSOFT_REDIRECT_URI (Web platform).
# HEFEST_MICROSOFT_TENANT is the Entra tenant id (GUID) for the edu.mon.bg directory —
# single-tenant: only @edu.mon.bg accounts can sign in.
HEFEST_MICROSOFT_CLIENT_ID=your-entra-app-client-id
HEFEST_MICROSOFT_CLIENT_SECRET=your-entra-app-client-secret
HEFEST_MICROSOFT_TENANT=your-edu-mon-bg-entra-tenant-id
HEFEST_MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# ── Shared OAuth ──────────────────────────────────────────────────────────────
# Where the API redirects the browser after a successful OAuth login.
# The SPA reads #access_token from the fragment and calls replaceState() to scrub it.
HEFEST_FRONTEND_OAUTH_SUCCESS_URL=http://localhost:5173/oauth
